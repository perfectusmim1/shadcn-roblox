	options = options or {}
	local theme = self.Window.Theme
	local state = options.Default == true
	local container = self:_container("Toggle", 54)
	local row = self:_row(container, options.Title or options.Text or "Toggle", options.Description, 54)

	local toggle = create("TextButton", {
		Name = "Toggle",
		AnchorPoint = Vector2.new(1, 0.5),
		AutoButtonColor = false,
		BackgroundColor3 = state and theme.Accent or theme.MutedSoft,
		BorderSizePixel = 0,
		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.fromOffset(48, 28),
		Text = "",
		Parent = row,
	})
	corner(toggle, RADIUS.Pill)

	local knob = create("Frame", {
		Name = "Knob",
		BackgroundColor3 = theme.Text,
		BorderSizePixel = 0,
		Position = state and UDim2.fromOffset(24, 4) or UDim2.fromOffset(4, 4),
		Size = UDim2.fromOffset(20, 20),
		Parent = toggle,
	})
	corner(knob, RADIUS.Pill)

	local api = {}

	local function render(instant)
		local color = state and theme.Accent or theme.MutedSoft
		local pos = state and UDim2.fromOffset(24, 4) or UDim2.fromOffset(4, 4)
		if instant then
			toggle.BackgroundColor3 = color
			knob.Position = pos
		else
			tween(toggle, TWEEN.Normal, { BackgroundColor3 = color })
			tween(knob, TWEEN.Spring, { Position = pos })
		end
	end

	function api:Set(value, silent)
		state = value == true
		render(false)
		if not silent and options.Callback then
			options.Callback(state)
		end
	end

	function api:Get()
		return state
	end

	self.Window:_connect(toggle.MouseButton1Click, function()
		api:Set(not state)
	end)

	if options.Tooltip then
		self.Window:_showTooltip(toggle, options.Tooltip)
	end

	return api
end

