	list(sliders, Enum.FillDirection.Vertical, 8)

	local open = false
	local api = {}
	local sliderRefs = {}

	local function fire(silent)
		swatch.BackgroundColor3 = color
		text.Text = colorToHex(color)
		if not silent and options.Callback then
			options.Callback(color)
		end
	end

	local function updateSliderVisual(channel, value)
		local ref = sliderRefs[channel]
		if not ref then
			return
		end
		ref.Value.Text = tostring(math.floor(value * 255 + 0.5))
		ref.Fill.Size = UDim2.new(value, 0, 1, 0)
		ref.Knob.Position = UDim2.fromScale(value, 0.5)
	end

	local function syncSliders()
		updateSliderVisual("R", color.R)
		updateSliderVisual("G", color.G)
		updateSliderVisual("B", color.B)
	end

	local function setColor(nextColor, silent)
		color = nextColor
		syncSliders()
		fire(silent)
	end

	local function rgbSlider(channel, accent)
		local wrap = create("Frame", {
			Name = channel .. "Slider",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			Parent = sliders,
		})

		makeLabel({
			Name = "Channel",
			Font = MEDIUM_FONT,
			Text = channel,
			TextColor3 = theme.TextMuted,
			TextSize = 12,
			Size = UDim2.fromOffset(18, 30),
			Parent = wrap,
		})

		local track = create("TextButton", {
			Name = "Track",
			AutoButtonColor = false,
			BackgroundColor3 = theme.MutedSoft,
			BorderSizePixel = 0,
			Position = UDim2.fromOffset(28, 11),
			Size = UDim2.new(1, -76, 0, 8),
			Text = "",
			Parent = wrap,
		})
		corner(track, RADIUS.Pill)

		local fill = create("Frame", {
			Name = "Fill",
			BackgroundColor3 = accent,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 0, 1, 0),
			Parent = track,
		})
		corner(fill, RADIUS.Pill)

		local knob = create("Frame", {
			Name = "Knob",
			AnchorPoint = Vector2.new(0.5, 0.5),
			BackgroundColor3 = theme.Text,
			BorderSizePixel = 0,
			Position = UDim2.fromScale(0, 0.5),
			Size = UDim2.fromOffset(14, 14),
			Parent = track,
		})
		corner(knob, RADIUS.Pill)

		local valueLabel = makeLabel({
			Name = "Value",
			Font = DEFAULT_FONT,
			Text = "0",
			TextColor3 = theme.TextMuted,
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Right,
			Position = UDim2.new(1, -40, 0, 0),
			Size = UDim2.fromOffset(40, 30),
			Parent = wrap,
		})

		sliderRefs[channel] = {
			Fill = fill,
			Knob = knob,
			Value = valueLabel,
		}

		local dragging = false
		local function setFromX(x)
			local alpha = clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
			local r, g, b = color.R, color.G, color.B
			if channel == "R" then
				r = alpha
			elseif channel == "G" then
				g = alpha
			else
				b = alpha
			end
			setColor(Color3.new(r, g, b), false)
		end

		self.Window:_connect(track.InputBegan, function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				setFromX(input.Position.X)
			end
		end)

		self.Window:_connect(UserInputService.InputChanged, function(input)
			if not dragging then
				return
			end
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				setFromX(input.Position.X)
			end
		end)

		self.Window:_connect(UserInputService.InputEnded, function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end

	for _, preset in ipairs(presetColors) do
		local presetButton = create("TextButton", {
			Name = "Preset",
			AutoButtonColor = false,
			BackgroundColor3 = preset,
			BorderSizePixel = 0,
			Size = UDim2.fromOffset(28, 28),
			Text = "",
			Parent = presets,
		})
		corner(presetButton, 7)
		stroke(presetButton, theme.Border, 0.2, 1)
		self.Window:_connect(presetButton.MouseButton1Click, function()
			setColor(preset, false)
		end)
	end

	rgbSlider("R", Color3.fromRGB(239, 68, 68))
	rgbSlider("G", Color3.fromRGB(34, 197, 94))
	rgbSlider("B", Color3.fromRGB(56, 139, 253))

	local function setOpen(value)
		open = value == true
		if open then
			panel.Visible = true
			tween(panel, TWEEN.Normal, { Size = UDim2.new(1, 0, 0, 164) })
		else
			tween(panel, TWEEN.Normal, { Size = UDim2.new(1, 0, 0, 0) })
			task.delay(0.22, function()
				if not open then
					panel.Visible = false
				end
			end)
		end
	end

	self.Window:_connect(button.MouseButton1Click, function()
		setOpen(not open)
	end)

	function api:Set(nextColor, silent)
		setColor(nextColor, silent)
	end

	function api:Get()
		return color
	end

	syncSliders()
	fire(true)
	return api
end

