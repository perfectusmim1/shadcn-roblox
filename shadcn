function Window:_showTooltip(target, text)
	if not text or text == "" then
		return
	end

	self:_connect(target.MouseEnter, function()
		self.TooltipText.Text = text
		self.Tooltip.Size = UDim2.fromOffset(math.min(280, math.max(160, #text * 6)), 42)
		self.Tooltip.BackgroundTransparency = 1
		self.TooltipStroke.Transparency = 1
		self.Tooltip.Visible = true
		setZIndexRecursive(self.Tooltip, 250)
		tween(self.Tooltip, TWEEN.Fast, { BackgroundTransparency = 0 })
		tween(self.TooltipStroke, TWEEN.Fast, { Transparency = 0 })
	end)

	self:_connect(target.MouseLeave, function()
		tween(self.Tooltip, TWEEN.Fast, { BackgroundTransparency = 1 })
		tween(self.TooltipStroke, TWEEN.Fast, { Transparency = 1 })
		task.delay(0.12, function()
			if self.Tooltip.BackgroundTransparency >= 0.95 then
				self.Tooltip.Visible = false
			end
		end)
	end)
end

function Window:SetVisible(visible)
	self.Gui.Enabled = visible == true
end

function Window:SetStatus(text)
	self.StatusPill.Text = tostring(text or "")
end

function Window:Destroy()
	for _, connection in ipairs(self._connections) do
		if connection.Connected then
			connection:Disconnect()
		end
	end
	table.clear(self._connections)
	if self.Gui then
		self.Gui:Destroy()
	end
end

function Window:_setActiveTab(tab)
	if self.ActiveTab == tab then
		return
	end

	for _, item in ipairs(self.Tabs) do
		local active = item == tab
		item.Page.Visible = active
		item.SidebarButton:SetAttribute("Active", active)
		item.MobileButton:SetAttribute("Active", active)
		item.SidebarButton.BackgroundColor3 = active and self.Theme.CardHover or self.Theme.Panel
		item.MobileButton.BackgroundColor3 = active and self.Theme.CardHover or self.Theme.Panel
		item.SidebarTitle.TextColor3 = active and self.Theme.Text or self.Theme.TextMuted
		item.MobileTitle.TextColor3 = active and self.Theme.Text or self.Theme.TextMuted
		item.SidebarAccent.BackgroundTransparency = active and 0 or 1
		item.MobileAccent.BackgroundTransparency = active and 0 or 1

		if active then
			item.Page.Position = UDim2.fromOffset(10, 0)
			tween(item.Page, TWEEN.Normal, { Position = UDim2.fromOffset(0, 0) })
		end
	end

	self.ActiveTab = tab
end

