	})

	makeLabel({
		Name = "Title",
		Font = MEDIUM_FONT,
		Text = options.Title or "Slider",
		TextColor3 = theme.Text,
		TextSize = 13,
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.new(1, -90, 0, 20),
		Parent = row,
	})

	local valueLabel = makeLabel({
		Name = "Value",
		Font = MEDIUM_FONT,
		Text = formatValue(value, decimals),
		TextColor3 = theme.TextMuted,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right,
		Position = UDim2.new(1, -90, 0, 0),
		Size = UDim2.fromOffset(90, 20),
		Parent = row,
	})

	local track = create("TextButton", {
		Name = "Track",
		AutoButtonColor = false,
		BackgroundColor3 = theme.MutedSoft,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 36),
		Size = UDim2.new(1, 0, 0, 8),
		Text = "",
		Parent = row,
	})
	corner(track, RADIUS.Pill)

	local fill = create("Frame", {
		Name = "Fill",
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		Parent = track,
	})
	corner(fill, RADIUS.Pill)

	local knob = create("Frame", {
		Name = "Knob",
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = theme.Text,
		BorderSizePixel = 0,
		Position = UDim2.fromScale(0, 0.5),
		Size = UDim2.fromOffset(18, 18),
		Parent = track,
	})
	corner(knob, RADIUS.Pill)
	stroke(knob, theme.Accent, 0.25, 2)

	if options.Description then
		makeLabel({
			Name = "Description",
			Font = DEFAULT_FONT,
			Text = options.Description,
			TextColor3 = theme.TextMuted,
			TextSize = 11,
			Position = UDim2.fromOffset(0, 52),
			Size = UDim2.new(1, 0, 0, 16),
			Parent = row,
		})
	end

	local api = {}
	local dragging = false

	local function render(animated)
		local alpha = map(value, minValue, maxValue, 0, 1)
		valueLabel.Text = (options.Prefix or "") .. formatValue(value, decimals) .. (options.Suffix or "")
		local goalFill = { Size = UDim2.new(alpha, 0, 1, 0) }
		local goalKnob = { Position = UDim2.fromScale(alpha, 0.5) }
		if animated then
			tween(fill, TWEEN.Fast, goalFill)
			tween(knob, TWEEN.Fast, goalKnob)
		else
			fill.Size = goalFill.Size
			knob.Position = goalKnob.Position
		end
	end

	local function setFromX(x, silent)
		local alpha = clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
		value = roundToStep(minValue + (maxValue - minValue) * alpha, step)
		value = clamp(value, minValue, maxValue)
		render(false)
		if not silent and options.Callback then
			options.Callback(value)
		end
	end

	function api:Set(nextValue, silent)
		value = clamp(roundToStep(nextValue, step), minValue, maxValue)
		render(true)
		if not silent and options.Callback then
			options.Callback(value)
		end
	end

	function api:Get()
		return value
	end

	self.Window:_connect(track.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setFromX(input.Position.X)
		end
	end)

	self.Window:_connect(UserInputService.InputChanged, function(input)
		if not dragging then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			setFromX(input.Position.X)
		end
	end)

	self.Window:_connect(UserInputService.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	render(false)
	return api
end

function Section:AddDropdown(options)
	options = options or {}
	local theme = self.Window.Theme
	local items = options.Items or {}
	local selected = options.Multi and {} or (options.Default or items[1])

	if options.Multi and type(options.Default) == "table" then
		for _, value in ipairs(options.Default) do
			selected[value] = true
		end
	end

	local container = self:_container("Dropdown", 54)
	local row = self:_row(container, options.Title or "Dropdown", options.Description, 54)

	local button = create("TextButton", {
		Name = "DropdownButton",
		AnchorPoint = Vector2.new(1, 0.5),
		AutoButtonColor = false,
		BackgroundColor3 = theme.Input,
		BorderSizePixel = 0,
		Font = DEFAULT_FONT,
		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.new(0.46, 0, 0, 36),
		Text = "",
		TextColor3 = theme.Text,
		TextSize = 12,
		Parent = row,
	})
	corner(button, RADIUS.Control)
	local buttonStroke = stroke(button, theme.Border, 0.2, 1)
	create("UISizeConstraint", {
		MaxSize = Vector2.new(options.Width or 190, 36),
		MinSize = Vector2.new(math.min(options.MinWidth or 112, options.Width or 190), 36),
		Parent = button,
	})

	local buttonText = makeLabel({
		Name = "Text",
		Font = DEFAULT_FONT,
		Text = "",
		TextColor3 = theme.Text,
		TextSize = 12,
		Position = UDim2.fromOffset(10, 0),
		Size = UDim2.new(1, -34, 1, 0),
		Parent = button,
	})

	makeLabel({
		Name = "Chevron",
		Font = SEMIBOLD_FONT,
		Text = "v",
		TextColor3 = theme.TextMuted,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Center,
		Position = UDim2.new(1, -28, 0, 0),
		Size = UDim2.fromOffset(24, 36),
		Parent = button,
	})

	local dropdown = create("Frame", {
		Name = "DropdownMenu",
		BackgroundColor3 = theme.Popover,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Size = UDim2.new(1, 0, 0, 0),
		Visible = false,
		Parent = container,
	})
	corner(dropdown, RADIUS.Control)
	stroke(dropdown, theme.Border, 0.1, 1)
	padding(dropdown, 6, 6, 6, 6)
	list(dropdown, Enum.FillDirection.Vertical, 4)

	local open = false
	local api = {}

	local function selectedArray()
		local values = {}
		for value, enabled in pairs(selected) do
			if enabled then
				table.insert(values, value)
			end
		end
		table.sort(values, function(a, b)
			return tostring(a) < tostring(b)
		end)
		return values
	end

	local function labelText()
		if options.Multi then
			local values = selectedArray()
			if #values == 0 then
				return options.Placeholder or "Select"
			end
			return table.concat(values, ", ")
		end
		return tostring(selected or options.Placeholder or "Select")
	end

	local function setOpen(value)
		open = value == true
		if open then
			dropdown.Visible = true
			tween(dropdown, TWEEN.Normal, { Size = UDim2.new(1, 0, 0, math.min(220, #items * 36 + 12)) })
			tween(buttonStroke, TWEEN.Fast, { Color = theme.Accent, Transparency = 0 })
		else
			tween(dropdown, TWEEN.Normal, { Size = UDim2.new(1, 0, 0, 0) })
			tween(buttonStroke, TWEEN.Fast, { Color = theme.Border, Transparency = 0.2 })
			task.delay(0.22, function()
				if not open then
					dropdown.Visible = false
				end
			end)
		end
	end

	local function fire()
		if options.Callback then
			if options.Multi then
				options.Callback(selectedArray())
			else
				options.Callback(selected)
			end
		end
	end

	function api:Set(value, silent)
		if options.Multi then
			selected = {}
			for _, item in ipairs(value or {}) do
				selected[item] = true
			end
		else
			selected = value
		end
		buttonText.Text = labelText()
		if not silent then
			fire()
		end
	end

	function api:Get()
		if options.Multi then
			return selectedArray()
		end
		return selected
	end

	for _, item in ipairs(items) do
		local optionButton = create("TextButton", {
			Name = "Option",
			AutoButtonColor = false,
			BackgroundColor3 = theme.Popover,
			BorderSizePixel = 0,
			Font = DEFAULT_FONT,
			Size = UDim2.new(1, 0, 0, 32),
			Text = "",
			Parent = dropdown,
		})
		corner(optionButton, 6)

		local label = makeLabel({
			Name = "Label",
			Font = DEFAULT_FONT,
			Text = tostring(item),
			TextColor3 = theme.Text,
			TextSize = 12,
			Position = UDim2.fromOffset(10, 0),
			Size = UDim2.new(1, -42, 1, 0),
			Parent = optionButton,
		})

		local check = makeLabel({
			Name = "Check",
			Font = SEMIBOLD_FONT,
			Text = "",
			TextColor3 = theme.Accent,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Center,
			Position = UDim2.new(1, -30, 0, 0),
			Size = UDim2.fromOffset(26, 32),
			Parent = optionButton,
		})

		local function renderOption()
			local active = options.Multi and selected[item] == true or selected == item
			check.Text = active and "✓" or ""
			label.TextColor3 = active and theme.Text or theme.TextMuted
			optionButton.BackgroundColor3 = active and theme.AccentSoft or theme.Popover
		end

		renderOption()

		self.Window:_connect(optionButton.MouseEnter, function()
			if optionButton.BackgroundColor3 ~= theme.AccentSoft then
				tween(optionButton, TWEEN.Fast, { BackgroundColor3 = theme.CardHover })
			end
		end)
		self.Window:_connect(optionButton.MouseLeave, renderOption)
		self.Window:_connect(optionButton.MouseButton1Click, function()
			if options.Multi then
				selected[item] = not selected[item]
			else
				selected = item
				setOpen(false)
			end
			for _, option in ipairs(dropdown:GetChildren()) do
				if option:IsA("TextButton") then
					local optionLabel = option:FindFirstChild("Label")
					local optionCheck = option:FindFirstChild("Check")
					if optionLabel and optionCheck then
						local optionValue = optionLabel.Text
						local active = options.Multi and selected[optionValue] == true or selected == optionValue
						optionCheck.Text = active and "✓" or ""
						optionLabel.TextColor3 = active and theme.Text or theme.TextMuted
						option.BackgroundColor3 = active and theme.AccentSoft or theme.Popover
					end
				end
			end
			buttonText.Text = labelText()
			fire()
		end)
	end

	self.Window:_connect(button.MouseButton1Click, function()
		setOpen(not open)
	end)

	buttonText.Text = labelText()
	return api
end

