function Section:AddTable(options)
	options = options or {}
	local theme = self.Window.Theme
	local columns = options.Columns or {}
	local rows = options.Rows or {}
	local rowHeight = options.RowHeight or 34
	local headerHeight = options.HeaderHeight or 36
	local visibleRows = options.VisibleRows or math.min(math.max(#rows, 1), 5)
	local tableHeight = headerHeight + visibleRows * rowHeight + 2
	local container = self:_container("Table", tableHeight)

	if options.Title then
		makeLabel({
			Name = "Title",
			Font = MEDIUM_FONT,
			Text = options.Title,
			TextColor3 = theme.Text,
			TextSize = 13,
			Size = UDim2.new(1, 0, 0, 20),
			Parent = container,
		})
	end

	local shell = create("Frame", {
		Name = "TableShell",
		BackgroundColor3 = theme.Input,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Size = UDim2.new(1, 0, 0, tableHeight),
		Parent = container,
	})
	corner(shell, RADIUS.Card)
	stroke(shell, theme.Border, 0.15, 1)

	local header = create("Frame", {
		Name = "Header",
		BackgroundColor3 = theme.CardHover,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, headerHeight),
		Parent = shell,
	})
	list(header, Enum.FillDirection.Horizontal, 0)

	local body = create("ScrollingFrame", {
		Name = "Body",
		Active = true,
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		CanvasSize = UDim2.fromScale(0, 0),
		Position = UDim2.fromOffset(0, headerHeight),
		ScrollBarImageColor3 = theme.MutedSoft,
		ScrollBarThickness = 3,
		Size = UDim2.new(1, 0, 1, -headerHeight),
		Parent = shell,
	})
	list(body, Enum.FillDirection.Vertical, 0)

	local function cell(parent, text, index, muted)
		local count = math.max(#columns, 1)
		local label = makeLabel({
			Name = "Cell" .. tostring(index),
			Font = muted and DEFAULT_FONT or MEDIUM_FONT,
			Text = tostring(text or ""),
			TextColor3 = muted and theme.TextMuted or theme.Text,
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1 / count, 0, 1, 0),
			Parent = parent,
		})
		padding(label, 10, 0, 10, 0)
		return label
	end

	for index, title in ipairs(columns) do
		cell(header, title, index, true)
	end

	local function renderRows(nextRows)
		for _, child in ipairs(body:GetChildren()) do
			if child:IsA("Frame") then
				child:Destroy()
			end
		end

		for rowIndex, rowData in ipairs(nextRows or {}) do
			local row = create("Frame", {
				Name = "Row",
				BackgroundColor3 = rowIndex % 2 == 0 and theme.Input or theme.Panel,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, rowHeight),
				Parent = body,
			})
			list(row, Enum.FillDirection.Horizontal, 0)

			for columnIndex = 1, math.max(#columns, #rowData) do
				cell(row, rowData[columnIndex], columnIndex, false)
			end
		end
	end

	renderRows(rows)

	local api = {}
	function api:SetRows(nextRows)
		rows = nextRows or {}
		renderRows(rows)
	end
	function api:GetRows()
		return rows
	end

	return api
end

function Window:Notify(options)
	options = options or {}
	local theme = self.Theme
	local viewport = getViewportSize()
	local toastWidth = math.min(316, math.max(260, viewport.X - 32))
	local tone = options.Tone or "Default"
	local accent = theme.Accent
	local soft = theme.AccentSoft

	if tone == "Success" then
		accent = theme.Success
		soft = theme.SuccessSoft
	elseif tone == "Warning" then
		accent = theme.Warning
		soft = theme.WarningSoft
	elseif tone == "Danger" then
		accent = theme.Danger
		soft = theme.DangerSoft
	end

	local toast = makeCanvasGroup({
		Name = "Toast",
		BackgroundColor3 = theme.Popover,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(toastWidth, options.Description and 82 or 62),
		Parent = self.ToastHost,
	})
	setGroupTransparency(toast, 1)
	toast.Position = UDim2.fromOffset(24, 0)
	corner(toast, RADIUS.Card)
	stroke(toast, theme.Border, 0.05, 1)

	create("Frame", {
		Name = "Accent",
		BackgroundColor3 = accent,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(10, 12),
		Size = UDim2.fromOffset(4, toast.Size.Y.Offset - 24),
		Parent = toast,
	})
	corner(toast.Accent, RADIUS.Pill)

	makeLabel({
		Name = "Title",
		Font = SEMIBOLD_FONT,
		Text = options.Title or "Notification",
		TextColor3 = theme.Text,
		TextSize = 13,
		Position = UDim2.fromOffset(24, 12),
		Size = UDim2.new(1, -46, 0, 18),
		Parent = toast,
	})

	if options.Description then
		makeLabel({
			Name = "Description",
			Font = DEFAULT_FONT,
			Text = options.Description,
			TextColor3 = theme.TextMuted,
			TextSize = 11,
			TextWrapped = true,
			Position = UDim2.fromOffset(24, 34),
			Size = UDim2.new(1, -42, 0, 36),
			Parent = toast,
		})
	end

	create("Frame", {
		Name = "Tone",
		AnchorPoint = Vector2.new(1, 0),
		BackgroundColor3 = soft,
		BorderSizePixel = 0,
		Position = UDim2.new(1, -12, 0, 12),
		Size = UDim2.fromOffset(10, 10),
		Parent = toast,
	})
	corner(toast.Tone, RADIUS.Pill)

	setZIndexRecursive(toast, 151)
	tween(toast, TWEEN.Normal, { Position = UDim2.fromOffset(0, 0) })
	if toast:IsA("CanvasGroup") then
		tween(toast, TWEEN.Normal, { GroupTransparency = 0 })
	else
		tween(toast, TWEEN.Normal, { BackgroundTransparency = 0 })
	end

	task.delay(options.Duration or 3.5, function()
		if not toast or not toast.Parent then
			return
		end
		tween(toast, TWEEN.Normal, { Position = UDim2.fromOffset(24, 0) })
		if toast:IsA("CanvasGroup") then
			tween(toast, TWEEN.Normal, { GroupTransparency = 1 })
		else
			tween(toast, TWEEN.Normal, { BackgroundTransparency = 1 })
		end
		task.delay(0.26, function()
			if toast and toast.Parent then
				toast:Destroy()
			end
		end)
	end)

	return toast
end

function Window:Confirm(options)
	options = options or {}
	local theme = self.Theme
	local viewport = getViewportSize()
	local dialogWidth = math.min(420, math.max(300, viewport.X - 28))
	local dialogHeight = options.Description and 210 or 178
	local tone = options.Tone or "Default"
	local accent = theme.Accent
	local soft = theme.AccentSoft

	if tone == "Danger" then
		accent = theme.Danger
		soft = theme.DangerSoft
	elseif tone == "Warning" then
		accent = theme.Warning
		soft = theme.WarningSoft
	elseif tone == "Success" then
		accent = theme.Success
		soft = theme.SuccessSoft
	end

	self.ModalHost:ClearAllChildren()
	self.ModalHost.Visible = true
	local modalConnections = {}

	local function modalConnect(signal, callback)
		local connection = signal:Connect(callback)
		table.insert(modalConnections, connection)
		return connection
	end

	local overlay = create("Frame", {
		Name = "Overlay",
		BackgroundColor3 = Color3.fromRGB(0, 0, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		ZIndex = 200,
		Parent = self.ModalHost,
	})

	local dialog = makeCanvasGroup({
		Name = "Dialog",
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = theme.Popover,
		BorderSizePixel = 0,
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(dialogWidth, dialogHeight),
		ZIndex = 205,
		Parent = self.ModalHost,
	})
	setGroupTransparency(dialog, 1)
	corner(dialog, RADIUS.Window)
	stroke(dialog, theme.BorderStrong, 0, 1)

	local dialogScale = create("UIScale", {
		Scale = 0.94,
		Parent = dialog,
	})

	create("Frame", {
		Name = "Tone",
		BackgroundColor3 = soft,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(18, 18),
		Size = UDim2.fromOffset(42, 42),
		ZIndex = 206,
		Parent = dialog,
	})
	corner(dialog.Tone, RADIUS.Control)

	makeLabel({
		Name = "ToneIcon",
		Font = SEMIBOLD_FONT,
		Text = tone == "Danger" and "!" or "?",
		TextColor3 = accent,
		TextSize = 18,
		TextXAlignment = Enum.TextXAlignment.Center,
		Size = UDim2.fromOffset(42, 42),
		ZIndex = 207,
		Parent = dialog.Tone,
	})

	makeLabel({
		Name = "Title",
		Font = SEMIBOLD_FONT,
		Text = options.Title or "Are you sure?",
		TextColor3 = theme.Text,
		TextSize = 17,
		Position = UDim2.fromOffset(74, 20),
		Size = UDim2.new(1, -92, 0, 24),
		ZIndex = 206,
		Parent = dialog,
	})

	makeLabel({
		Name = "Description",
		Font = DEFAULT_FONT,
		Text = options.Description or "This action cannot be completed without confirmation.",
		TextColor3 = theme.TextMuted,
		TextSize = 12,
		TextWrapped = true,
		LineHeight = 1.12,
		Position = UDim2.fromOffset(74, 48),
		Size = UDim2.new(1, -92, 0, 56),
		ZIndex = 206,
		Parent = dialog,
	})

	local buttonRow = create("Frame", {
		Name = "Buttons",
		AnchorPoint = Vector2.new(1, 1),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(1, -18, 1, -18),
		Size = UDim2.fromOffset(250, 38),
		ZIndex = 206,
		Parent = dialog,
	})
	list(buttonRow, Enum.FillDirection.Horizontal, 8, Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Center)

	local cancel = create("TextButton", {
		Name = "Cancel",
		AutoButtonColor = false,
		BackgroundColor3 = theme.Input,
		BorderSizePixel = 0,
		Font = MEDIUM_FONT,
		Size = UDim2.fromOffset(112, 38),
		Text = options.CancelText or "No",
		TextColor3 = theme.Text,
		TextSize = 13,
		ZIndex = 207,
		Parent = buttonRow,
	})
	corner(cancel, RADIUS.Control)
	stroke(cancel, theme.Border, 0.2, 1)

	local confirm = create("TextButton", {
		Name = "Confirm",
		AutoButtonColor = false,
		BackgroundColor3 = accent,
		BorderSizePixel = 0,
		Font = SEMIBOLD_FONT,
		Size = UDim2.fromOffset(112, 38),
		Text = options.ConfirmText or "Yes",
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 13,
		ZIndex = 207,
		Parent = buttonRow,
	})
	corner(confirm, RADIUS.Control)

	local function close(runCallback)
		tween(overlay, TWEEN.Normal, { BackgroundTransparency = 1 })
		if dialog:IsA("CanvasGroup") then
			tween(dialog, TWEEN.Normal, { GroupTransparency = 1 })
		else
			tween(dialog, TWEEN.Normal, { BackgroundTransparency = 1 })
		end
		tween(dialogScale, TWEEN.Normal, { Scale = 0.94 })
		task.delay(0.2, function()
			for _, connection in ipairs(modalConnections) do
				if connection.Connected then
					connection:Disconnect()
				end
			end
			self.ModalHost.Visible = false
			self.ModalHost:ClearAllChildren()
			if runCallback and options.OnConfirm then
				options.OnConfirm()
			elseif (not runCallback) and options.OnCancel then
				options.OnCancel()
			end
		end)
	end

	modalConnect(cancel.MouseButton1Click, function()
		close(false)
	end)

	modalConnect(confirm.MouseButton1Click, function()
		close(true)
	end)

	tween(overlay, TWEEN.Normal, { BackgroundTransparency = 0.42 })
	if dialog:IsA("CanvasGroup") then
		tween(dialog, TWEEN.Normal, { GroupTransparency = 0 })
	else
		tween(dialog, TWEEN.Normal, { BackgroundTransparency = 0 })
	end
	tween(dialogScale, TWEEN.Spring, { Scale = 1 })
end

function Shadcn.CreateWindow(options)
	options = options or {}
	local player = Players.LocalPlayer
	local parent = options.Parent

	if not parent then
		assert(player, "ShadcnRoblox must be required from a LocalScript or given a Parent Gui.")
		parent = player:WaitForChild("PlayerGui")
	end

	local window = setmetatable({
		Options = options,
		Parent = parent,
		Theme = cloneTheme(options.Theme),
		Tabs = {},
		ActiveTab = nil,
		_connections = {},
		IsMobile = false,
	}, Window)

	window:_createBase()
	return window
end

