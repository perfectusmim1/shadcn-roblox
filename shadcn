function Window:_applyResponsive()
	local viewport = getViewportSize()
	local margin = viewport.X < 680 and 12 or 28
	local maxWidth = math.max(300, viewport.X - margin * 2)
	local maxHeight = math.max(320, viewport.Y - margin * 2)
	local desiredWidth = self.Options.Width or 980
	local desiredHeight = self.Options.Height or 620
	local width = math.min(desiredWidth, maxWidth)
	local height = math.min(desiredHeight, maxHeight)
	local mobile = width < 700
	local compact = width < 860

	self.Root.Size = UDim2.fromOffset(width, height)
	self.IsMobile = mobile
	self.ToastHost.Size = UDim2.fromOffset(math.min(330, math.max(280, viewport.X - 24)), 460)

	if mobile then
		self.SearchBox.Visible = false
		self.StatusPill.Visible = false
		self.Sidebar.Visible = false
		self.MobileTabs.Visible = true
		self.Content.Position = UDim2.fromOffset(0, 112)
