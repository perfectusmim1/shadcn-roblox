		if listening then
			if input.KeyCode ~= Enum.KeyCode.Unknown then
				set(input.KeyCode)
			end
			return
		end
		if input.KeyCode == key and options.Callback then
			options.Callback(key)
		end
	end)

	function api:Set(nextKey, silent)
		set(nextKey, silent)
	end

	function api:Get()
		return key
	end

	return api
end

