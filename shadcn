local function cloneTheme(overrides)
	local theme = {}
	for key, value in pairs(THEME) do
		theme[key] = value
	end
	for key, value in pairs(overrides or {}) do
		theme[key] = value
	end
	return theme
end

local function create(className, props, children)
	local instance = Instance.new(className)
	local parent = nil

	for key, value in pairs(props or {}) do
		if key == "Parent" then
			parent = value
		else
			instance[key] = value
		end
	end

	for _, child in ipairs(children or {}) do
		child.Parent = instance
	end

	if parent then
		instance.Parent = parent
	end

	return instance
end

local function corner(parent, radius)
	return create("UICorner", {
		CornerRadius = UDim.new(0, radius or RADIUS.Control),
		Parent = parent,
	})
end

local function stroke(parent, color, transparency, thickness)
	return create("UIStroke", {
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Color = color,
		Transparency = transparency or 0,
		Thickness = thickness or 1,
		Parent = parent,
	})
end

local function padding(parent, left, top, right, bottom)
	return create("UIPadding", {
		PaddingLeft = UDim.new(0, left or 0),
		PaddingTop = UDim.new(0, top or 0),
		PaddingRight = UDim.new(0, right or left or 0),
		PaddingBottom = UDim.new(0, bottom or top or 0),
		Parent = parent,
	})
end

local function list(parent, direction, spacing, horizontalAlignment, verticalAlignment)
	return create("UIListLayout", {
		FillDirection = direction or Enum.FillDirection.Vertical,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, spacing or 8),
		HorizontalAlignment = horizontalAlignment or Enum.HorizontalAlignment.Left,
		VerticalAlignment = verticalAlignment or Enum.VerticalAlignment.Top,
		Parent = parent,
	})
end

local function grid(parent, cellSize, spacing)
	return create("UIGridLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		CellSize = cellSize,
		CellPadding = spacing or UDim2.fromOffset(8, 8),
		Parent = parent,
	})
end

local function tween(instance, tweenInfo, goal)
	local item = TweenService:Create(instance, tweenInfo or TWEEN.Normal, goal)
	item:Play()
	return item
end

local function makeLabel(props)
	return create("TextLabel", {
		Name = props.Name or "Label",
		BackgroundTransparency = 1,
		Font = props.Font or DEFAULT_FONT,
		Text = props.Text or "",
		TextColor3 = props.TextColor3 or THEME.Text,
		TextSize = props.TextSize or 14,
		TextTransparency = props.TextTransparency or 0,
		TextWrapped = props.TextWrapped == true,
		TextTruncate = props.TextTruncate or Enum.TextTruncate.AtEnd,
		TextXAlignment = props.TextXAlignment or Enum.TextXAlignment.Left,
		TextYAlignment = props.TextYAlignment or Enum.TextYAlignment.Center,
		LineHeight = props.LineHeight or 1,
		AutomaticSize = props.AutomaticSize or Enum.AutomaticSize.None,
		Size = props.Size or UDim2.fromScale(1, 1),
		Position = props.Position or UDim2.fromScale(0, 0),
		AnchorPoint = props.AnchorPoint or Vector2.new(0, 0),
		LayoutOrder = props.LayoutOrder or 0,
		ZIndex = props.ZIndex or 1,
		Parent = props.Parent,
	})
end

local function colorToHex(color)
	local r = math.floor(color.R * 255 + 0.5)
	local g = math.floor(color.G * 255 + 0.5)
	local b = math.floor(color.B * 255 + 0.5)
	return string.format("#%02X%02X%02X", r, g, b)
end

local function clamp(value, minValue, maxValue)
	if value < minValue then
		return minValue
	end
	if value > maxValue then
		return maxValue
	end
	return value
end

local function roundToStep(value, step)
	if not step or step <= 0 then
		return value
	end
	return math.floor((value / step) + 0.5) * step
end

local function formatValue(value, decimals)
	if decimals and decimals > 0 then
		return string.format("%." .. tostring(decimals) .. "f", value)
	end
	return tostring(math.floor(value + 0.5))
end

local function map(value, minValue, maxValue, outMin, outMax)
	if maxValue == minValue then
		return outMin
	end
	local alpha = (value - minValue) / (maxValue - minValue)
	return outMin + (outMax - outMin) * alpha
end

local function getViewportSize()
	local camera = workspace.CurrentCamera
	if camera then
		return camera.ViewportSize
	end
	return Vector2.new(1280, 720)
end

local function setZIndexRecursive(instance, zIndex)
	if instance:IsA("GuiObject") then
		instance.ZIndex = zIndex
	end
	for _, child in ipairs(instance:GetChildren()) do
		setZIndexRecursive(child, zIndex)
	end
end

local function makeCanvasGroup(props)
	local ok, group = pcall(function()
		return Instance.new("CanvasGroup")
	end)
	if not ok then
		group = Instance.new("Frame")
	end
	for key, value in pairs(props or {}) do
		group[key] = value
	end
	return group
end

local function setGroupTransparency(group, value)
	if group:IsA("CanvasGroup") then
		group.GroupTransparency = value
	else
		group.BackgroundTransparency = value
	end
end

local function addButtonAnimation(window, button, options)
	local function resolve(value)
		if type(value) == "function" then
			return value()
		end
		return value
	end

	local scale = create("UIScale", {
		Scale = 1,
		Parent = button,
	})
	local strokeObject = options.StrokeObject

	window:_connect(button.MouseEnter, function()
		local baseColor = resolve(options.BaseColor)
		local hoverColor = resolve(options.HoverColor)
		local baseStroke = resolve(options.Stroke)
		local hoverStroke = resolve(options.HoverStroke) or baseStroke
		if baseColor and hoverColor then
			tween(button, TWEEN.Fast, { BackgroundColor3 = hoverColor })
		end
		if strokeObject and hoverStroke then
			tween(strokeObject, TWEEN.Fast, { Color = hoverStroke, Transparency = 0 })
		end
	end)

	window:_connect(button.MouseLeave, function()
		local baseColor = resolve(options.BaseColor)
		local baseStroke = resolve(options.Stroke)
		tween(scale, TWEEN.Fast, { Scale = 1 })
		if baseColor then
			tween(button, TWEEN.Fast, { BackgroundColor3 = baseColor })
		end
		if strokeObject and baseStroke then
			tween(strokeObject, TWEEN.Fast, { Color = baseStroke, Transparency = options.StrokeTransparency or 0 })
		end
	end)

	window:_connect(button.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local downColor = resolve(options.DownColor) or resolve(options.HoverColor)
			tween(scale, TWEEN.Fast, { Scale = 0.985 })
			if downColor then
				tween(button, TWEEN.Fast, { BackgroundColor3 = downColor })
			end
		end
	end)

	window:_connect(button.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local baseColor = resolve(options.BaseColor)
			tween(scale, TWEEN.Fast, { Scale = 1 })
			if baseColor then
				tween(button, TWEEN.Fast, { BackgroundColor3 = baseColor })
			end
		end
	end)
end

function Window:_connect(signal, callback)
	local connection = signal:Connect(callback)
	table.insert(self._connections, connection)
	return connection
end

function Window:_bindDragging()
	local dragging = false
	local dragStart = nil
	local startPosition = nil

	self:_connect(self.Topbar.InputBegan, function(input)
		local isDragInput = input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch
		if not isDragInput then
			return
		end
		dragging = true
		dragStart = input.Position
		startPosition = self.Root.Position
	end)

	self:_connect(UserInputService.InputChanged, function(input)
		if not dragging then
			return
		end
		local isMove = input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch
		if not isMove then
			return
		end
		local delta = input.Position - dragStart
		self.Root.Position = UDim2.new(
			startPosition.X.Scale,
			startPosition.X.Offset + delta.X,
			startPosition.Y.Scale,
			startPosition.Y.Offset + delta.Y
		)
	end)

	self:_connect(UserInputService.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
end

