--[[
	ShadcnRoblox.lua
	Single-file shadcn-inspired UI library for Roblox.

	Usage:
		1. Put this file in a ModuleScript named "ShadcnRoblox".
		2. Require it from a LocalScript:

			local Shadcn = require(path.To.ShadcnRoblox)
			local app = Shadcn.CreateDemo()

		3. Or build your own UI:

			local Shadcn = require(path.To.ShadcnRoblox)
			local window = Shadcn.CreateWindow({
				Title = "Admin",
				Subtitle = "Control panel",
			})

			local tab = window:AddTab({ Title = "Dashboard", Icon = "D" })
			local section = tab:AddSection({ Title = "Controls" })
			section:AddButton({ Text = "Run", Callback = function() print("clicked") end })

	Design goals:
		- One file, no external UI dependencies.
		- Responsive desktop/mobile layout.
		- Custom modal, toast, tooltip, dropdown and confirm UI.
		- Smooth TweenService animations with restrained shadcn-like colors.
]]

