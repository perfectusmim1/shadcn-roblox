local function setToggleState(value, instant)
	smartToggle = value
	local properties = {
		BackgroundColor3 = value and theme.accent or theme.borderSoft,
	}
	if instant then
		toggle.BackgroundColor3 = properties.BackgroundColor3
	else
		tween(toggle, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), properties)
	end

	local knobPosition = value and UDim2.new(1, -27, 0.5, 0) or UDim2.new(0, 27, 0.5, 0)
	if instant then
		toggleKnob.Position = knobPosition
	else
		tween(toggleKnob, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Position = knobPosition,
		})
	end
end

local sliderValue = 0.72

local function setSliderValue(value, instant)
	sliderValue = math.clamp(value, 0.05, 1)
	local fillSize = UDim2.new(sliderValue, 0, 1, 0)
	local knobPos = UDim2.new(sliderValue, 0, 0.5, 0)
	local budgetAmount = math.floor(1000 + sliderValue * 4500)
	budgetValue.Text = "$" .. string.format("%.1fk", budgetAmount / 1000)
	if instant then
		sliderFill.Size = fillSize
		sliderKnob.Position = knobPos
	else
		tween(sliderFill, TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = fillSize})
		tween(sliderKnob, TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = knobPos})
	end
end

local function updateSliderFromInput(inputPosition)
	local relative = (inputPosition.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X
	setSliderValue(relative, false)
end

