function Section:CreateSlider(options)
	options = options or {}
	local min = options.Min or 0
	local max = options.Max or 100
	local value = math.clamp(options.Default or min, min, max)
	local dragging = false

	local row = create("Frame", {
		BackgroundColor3 = theme.panel,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 72),
		ZIndex = 14,
		Parent = self.content,
	})
	round(row, 14)
	stroke(row, theme.stroke, 1, 0.28)

	create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamSemibold,
		Position = UDim2.new(0, 14, 0, 10),
		Size = UDim2.new(1, -90, 0, 18),
		Text = options.Title or "Slider",
		TextColor3 = theme.text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 15,
		Parent = row,
	})

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamMedium,
		Position = UDim2.new(1, -74, 0, 10),
		Size = UDim2.new(0, 60, 0, 18),
		Text = tostring(value),
		TextColor3 = theme.textSoft,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right,
		ZIndex = 15,
		Parent = row,
	})

	local track = create("Frame", {
		BackgroundColor3 = theme.panelAlt,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 14, 0, 46),
		Size = UDim2.new(1, -28, 0, 6),
		ZIndex = 15,
		Parent = row,
	})
	round(track, 999)

	local fill = create("Frame", {
		BackgroundColor3 = theme.accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		ZIndex = 16,
		Parent = track,
	})
	round(fill, 999)

	local knob = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = theme.text,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0.5, 0),
		Size = UDim2.fromOffset(14, 14),
		ZIndex = 17,
		Parent = track,
	})
	round(knob, 999)
	stroke(knob, theme.accent, 2, 0.15)

	local function set(newValue, doCallback)
		value = math.clamp(newValue, min, max)
		local alpha = (value - min) / math.max(max - min, 1)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, 0, 0.5, 0)
		valueLabel.Text = tostring(math.floor(value * 100) / 100)
		if doCallback and options.Callback then
			options.Callback(value)
		end
	end

	local function updateFromPosition(positionX)
		local alpha = math.clamp((positionX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		set(min + (max - min) * alpha, true)
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromPosition(input.Position.X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromPosition(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	set(value, false)

	return {
		Set = function(_, newValue)
			set(newValue, true)
		end,
		Get = function()
			return value
		end,
	}
end

