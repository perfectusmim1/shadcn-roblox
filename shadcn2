		ZIndex = 15,
	})
	keyButton.AnchorPoint = Vector2.new(1, 0.5)
	keyButton.Position = UDim2.new(1, -12, 0.5, 0)

	keyButton.MouseButton1Click:Connect(function()
		listening = true
		keyButton.Text = "..."
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if listening and input.UserInputType == Enum.UserInputType.Keyboard then
			listening = false
			current = input.KeyCode
			keyButton.Text = current.Name
			if options.OnChanged then
				options.OnChanged(current)
			end
			return
		end

		if not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == current then
			if options.Callback then
				options.Callback(current)
			end
		end
	end)

	return {
		Set = function(_, keyCode)
			current = keyCode
			keyButton.Text = keyCode.Name
		end,
		Get = function()
			return current
		end,
	}
