local function closeModal()
	if not modal.Visible then
		return
	end

	local fade = tween(scrim, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		BackgroundTransparency = 1,
	})
	tween(modalScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Scale = 0.92,
	})
	local slide = tween(modal, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		BackgroundTransparency = 1,
		Position = UDim2.fromScale(0.5, 0.55),
	})
	slide.Completed:Connect(function()
		modal.Visible = false
		scrim.Visible = false
	end)
	fade.Completed:Connect(function() end)
end

local function openModal(title, body, onConfirm)
	currentConfirmAction = onConfirm
	modalTitle.Text = title
	modalBody.Text = body
	scrim.Visible = true
	modal.Visible = true
	scrim.BackgroundTransparency = 1
	modal.BackgroundTransparency = 1
	modal.Position = UDim2.fromScale(0.5, 0.55)
	modalScale.Scale = 0.92
	tween(scrim, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.3,
	})
	tween(modalScale, TweenInfo.new(0.24, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Scale = 1,
	})
	tween(modal, TweenInfo.new(0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		Position = UDim2.fromScale(0.5, 0.5),
	})
end

scrim.MouseButton1Click:Connect(closeModal)
modalCancel.MouseButton1Click:Connect(closeModal)
modalConfirm.MouseButton1Click:Connect(function()
	local confirm = currentConfirmAction
	closeModal()
	if confirm then
		confirm()
	end
end)

local function makeNavItem(parent, label, tag)
	local button = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = theme.panel,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 46),
		Text = "",
		Parent = parent,
	})
	addCorner(button, 14)

	local indicator = create("Frame", {
		BackgroundColor3 = theme.accent,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0.5, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		Size = UDim2.fromOffset(3, 0),
		Parent = button,
	})
	addCorner(indicator, 999)

	local iconFrame = create("Frame", {
		BackgroundColor3 = theme.cardAlt,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 10, 0.5, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		Size = UDim2.fromOffset(28, 28),
		Parent = button,
	})
	addCorner(iconFrame, 10)
	addStroke(iconFrame, theme.border, 1, 0.45)

	local iconText = create("TextLabel", {
		BackgroundTransparency = 1,
		FontFace = fontFaceSemibold,
		Text = tag,
		TextColor3 = theme.textSoft,
		TextSize = 11,
		Size = UDim2.fromScale(1, 1),
		Parent = iconFrame,
	})

	local labelText = create("TextLabel", {
		BackgroundTransparency = 1,
		FontFace = fontFaceMedium,
		Text = label,
		TextColor3 = theme.textSoft,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.new(0, 52, 0, 0),
		Size = UDim2.new(1, -62, 1, 0),
		Parent = button,
	})

	local active = false
	local function setActive(state)
		active = state
		tween(button, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			BackgroundColor3 = state and theme.cardAlt or theme.panel,
		})
		tween(indicator, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = state and UDim2.fromOffset(3, 24) or UDim2.fromOffset(3, 0),
		})
		tween(iconFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			BackgroundColor3 = state and theme.accentSoft or theme.cardAlt,
		})
		iconText.TextColor3 = state and theme.text or theme.textSoft
		labelText.TextColor3 = state and theme.text or theme.textSoft
	end

	button.MouseEnter:Connect(function()
		if not active then
			tween(button, TweenInfo.new(0.14, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = theme.card})
		end
	end)

	button.MouseLeave:Connect(function()
		if not active then
			tween(button, TweenInfo.new(0.14, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = theme.panel})
		end
	end)

	return button, setActive, iconFrame, labelText
end

