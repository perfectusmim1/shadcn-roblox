local function pushToast(title, message, tone)
	local toneColor = theme.accent
	if tone == "success" then
		toneColor = theme.success
	elseif tone == "warning" then
		toneColor = theme.warning
	elseif tone == "danger" then
		toneColor = theme.danger
	end

	local toast = create("Frame", {
		AnchorPoint = Vector2.new(1, 0),
		BackgroundColor3 = theme.panel,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(320, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundTransparency = 0.04,
		ZIndex = 60,
		Parent = toastStack,
	})
	addCorner(toast, 16)
	addStroke(toast, theme.borderSoft, 1, 0.16)
	addPadding(toast, 14, 14, 12, 12)

	local bar = create("Frame", {
		BackgroundColor3 = toneColor,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(0, 4, 1, 0),
		ZIndex = 61,
		Parent = toast,
	})
	addCorner(bar, 999)

	local titleLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		FontFace = fontFaceSemibold,
		Text = title,
		TextColor3 = theme.text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.new(0, 12, 0, 0),
		Size = UDim2.new(1, -12, 0, 20),
		ZIndex = 61,
		Parent = toast,
	})

	local bodyLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		FontFace = fontFace,
		Text = message,
		TextColor3 = theme.textSoft,
		TextSize = 12,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		AutomaticSize = Enum.AutomaticSize.Y,
		Position = UDim2.new(0, 12, 0, 22),
		Size = UDim2.new(1, -12, 0, 0),
		ZIndex = 61,
		Parent = toast,
	})

	toast.Position = UDim2.new(1, 40, 0, 0)
	toast.BackgroundTransparency = 1
	tween(toast, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = UDim2.new(1, 0, 0, 0),
		BackgroundTransparency = 0.04,
	})

	task.delay(4.2, function()
		if toast.Parent then
			local fade = tween(toast, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
				Position = UDim2.new(1, 36, 0, 0),
				BackgroundTransparency = 1,
			})
			fade.Completed:Connect(function()
				if toast.Parent then
					toast:Destroy()
				end
			end)
		end
	end)
end

