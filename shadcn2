local function makeInteractiveButton(parent, options)
	local tone = options.Tone or "secondary"
	local palette = {
		primary = {
			bg = theme.text,
			hover = Color3.fromRGB(255, 255, 255),
			text = theme.surface,
			stroke = Color3.fromRGB(255, 255, 255),
		},
		secondary = {
			bg = theme.panelAlt,
			hover = lighten(theme.panelAlt, 0.07),
			text = theme.text,
			stroke = theme.stroke,
		},
		danger = {
			bg = Color3.fromRGB(84, 28, 32),
			hover = Color3.fromRGB(105, 35, 39),
			text = Color3.fromRGB(255, 227, 230),
			stroke = Color3.fromRGB(125, 48, 54),
		},
	}
	local colors = palette[tone]

	local button = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = colors.bg,
		BorderSizePixel = 0,
		Font = Enum.Font.GothamMedium,
		Size = options.Size or UDim2.new(0, 110, 0, 36),
		Text = options.Text or "Button",
		TextColor3 = colors.text,
		TextSize = options.TextSize or 13,
		ZIndex = options.ZIndex or 1,
		Parent = parent,
	})
	round(button, options.Radius or 12)
	stroke(button, colors.stroke, 1, tone == "primary" and 0.7 or 0.45)

	local scale = create("UIScale", {
		Scale = 1,
		Parent = button,
	})

	button.MouseEnter:Connect(function()
		tween(button, TweenInfo.new(0.14, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = colors.hover})
	end)

	button.MouseLeave:Connect(function()
		tween(button, TweenInfo.new(0.14, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = colors.bg})
		tween(scale, TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Scale = 1})
	end)

	button.MouseButton1Down:Connect(function()
		tween(scale, TweenInfo.new(0.07, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.97})
	end)

	button.MouseButton1Up:Connect(function()
		tween(scale, TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Scale = 1})
	end)

	return button
end

function Library:Notify(options)
	ensureRoot()

	options = options or {}
	local title = options.Title or "Notification"
	local content = options.Content or ""
	local duration = options.Duration or 4
	local tone = options.Tone or "accent"

	local accentColor = theme.accent
	if tone == "success" then
		accentColor = theme.success
	elseif tone == "warning" then
		accentColor = theme.warning
	elseif tone == "danger" then
		accentColor = theme.danger
	end

	local toast = create("Frame", {
		AnchorPoint = Vector2.new(1, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = theme.panel,
		BorderSizePixel = 0,
		Position = UDim2.new(1, 40, 0, 0),
		Size = UDim2.fromOffset(330, 0),
		ZIndex = 120,
		Parent = state.notifyStack,
	})
	round(toast, 16)
	stroke(toast, theme.strokeSoft, 1, 0.18)
	padding(toast, 14, 14, 12, 12)

	create("Frame", {
		BackgroundColor3 = accentColor,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 4, 1, 0),
		ZIndex = 121,
		Parent = toast,
	})
	round(toast:FindFirstChildOfClass("Frame"), 999)

	create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamSemibold,
		Position = UDim2.new(0, 12, 0, 0),
		Size = UDim2.new(1, -12, 0, 20),
		Text = title,
		TextColor3 = theme.text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 121,
		Parent = toast,
	})

	create("TextLabel", {
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundTransparency = 1,
		Font = Enum.Font.Gotham,
		Position = UDim2.new(0, 12, 0, 22),
		Size = UDim2.new(1, -12, 0, 0),
		Text = content,
		TextColor3 = theme.textSoft,
		TextSize = 12,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 121,
		Parent = toast,
