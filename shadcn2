	})

	return self
end

function Window:SelectTab(tabObject)
	if self.activeTab == tabObject then
		return
	end

	self.activeTab = tabObject
	for _, tab in ipairs(self.tabs) do
		local isActive = tab == tabObject
		tab.page.Visible = isActive
		tween(tab.button, TweenInfo.new(0.16, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			BackgroundColor3 = isActive and theme.panelSoft or theme.panel,
		})
		tween(tab.indicator, TweenInfo.new(0.16, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = isActive and UDim2.fromOffset(3, 24) or UDim2.fromOffset(3, 0),
		})
		tab.label.TextColor3 = isActive and theme.text or theme.textSoft
		tab.iconFrame.BackgroundColor3 = isActive and theme.accentSoft or theme.panelAlt
	end
end

