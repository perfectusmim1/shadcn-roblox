local function makeButton(parent, text, width, tone)
	local palette = {
		primary = {bg = theme.text, text = theme.surface, hover = alphaColor(theme.text, 0.08)},
		secondary = {bg = theme.cardAlt, text = theme.text, hover = alphaColor(theme.cardAlt, 0.15)},
		ghost = {bg = theme.panel, text = theme.textSoft, hover = alphaColor(theme.panelSoft, 0.14)},
		danger = {bg = Color3.fromRGB(84, 26, 31), text = Color3.fromRGB(255, 221, 223), hover = Color3.fromRGB(104, 32, 39)},
	}
	local toneColors = palette[tone or "secondary"]
	local button = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = toneColors.bg,
		BorderSizePixel = 0,
		FontFace = fontFaceMedium,
		Size = UDim2.new(0, width or 110, 0, 36),
		Text = text,
		TextColor3 = toneColors.text,
		TextSize = 13,
		Parent = parent,
	})
	addCorner(button, 12)
	addStroke(button, theme.border, 1, 0.55)

	local pressScale = create("UIScale", {
		Scale = 1,
		Parent = button,
	})

	button.MouseEnter:Connect(function()
		tween(button, TweenInfo.new(0.16, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = toneColors.hover})
	end)

	button.MouseLeave:Connect(function()
		tween(button, TweenInfo.new(0.16, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = toneColors.bg})
		tween(pressScale, TweenInfo.new(0.16, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Scale = 1})
	end)

	button.MouseButton1Down:Connect(function()
		tween(pressScale, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.97})
	end)

	button.MouseButton1Up:Connect(function()
		tween(pressScale, TweenInfo.new(0.14, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Scale = 1})
	end)

	return button
end

