local function applyMode(mode)
	currentMode = mode
	isMobile = mode == "mobile"

	local sidebarTargetWidth = mode == "desktop" and 232 or 92
	if isMobile then
		sidebarTargetWidth = 240
	end

	local topRightWidth = mode == "desktop" and 0.42 or 0.5
	if isMobile then
		topRightWidth = 0.34
	end

	local menuVisible = isMobile
	topMenuButton.Visible = menuVisible
	searchBar.Position = menuVisible and UDim2.new(0, 58, 0, 0) or UDim2.new(0, 0, 0, 0)
	searchBar.Size = menuVisible and UDim2.new(1, -58, 0, 46) or UDim2.new(1, -18, 0, 46)

	topBarLeft.Size = isMobile and UDim2.new(1, -188, 1, 0) or UDim2.new(0.58, 0, 1, 0)
	topBarRight.Size = isMobile and UDim2.new(0, 176, 1, 0) or UDim2.new(topRightWidth, 0, 1, 0)

	inboxPill.Visible = not isMobile
	datePill.Visible = not isMobile
	profileButton.Size = isMobile and UDim2.new(0, 176, 0, 46) or UDim2.new(0, 190, 0, 46)

	sidebar.Size = UDim2.new(0, sidebarTargetWidth, 1, 0)
	mainArea.Size = isMobile and UDim2.new(1, 0, 1, 0) or UDim2.new(1, -(sidebarTargetWidth + 18), 1, 0)

	if isMobile then
		sidebar.Parent = overlay
		sidebar.ZIndex = 45
		sidebar.Position = sidebarOpen and UDim2.new(0, 20, 0, 20) or UDim2.new(0, -260, 0, 20)
		sidebar.Size = UDim2.new(0, 240, 1, -40)
		scrim.Visible = sidebarOpen
		scrim.BackgroundTransparency = sidebarOpen and 0.42 or 1
	else
		if sidebar.Parent ~= contentRow then
			sidebar.Parent = contentRow
		end
		sidebar.ZIndex = 1
		sidebar.Position = UDim2.new(0, 0, 0, 0)
		scrim.Visible = modal.Visible
		scrim.BackgroundTransparency = modal.Visible and 0.3 or 1
	end

	local compactSidebar = mode == "tablet"
	brandTextWrap.Visible = not compactSidebar
	navLabel.Visible = not compactSidebar
	footerCard.Visible = not compactSidebar
	footerSpacer.Visible = not compactSidebar
	sidebar.Size = isMobile and sidebar.Size or UDim2.new(0, compactSidebar and 92 or 232, 1, 0)
	mainArea.Size = isMobile and mainArea.Size or UDim2.new(1, -(compactSidebar and 110 or 250), 1, 0)

	for _, entry in ipairs(navButtons) do
		local button = entry.button
		local iconFrame = entry.iconFrame
		local labelText = entry.labelText
		if compactSidebar then
			button.Size = UDim2.new(1, 0, 0, 46)
			iconFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
			iconFrame.AnchorPoint = Vector2.new(0.5, 0.5)
			labelText.Visible = false
		else
			iconFrame.Position = UDim2.new(0, 10, 0.5, 0)
			iconFrame.AnchorPoint = Vector2.new(0, 0.5)
			labelText.Visible = true
		end
	end

	local heroVertical = isMobile
	heroGrid.Size = UDim2.new(1, 0, 0, heroVertical and 1602 or 522)
	heroGridLayout.FillDirection = heroVertical and Enum.FillDirection.Vertical or Enum.FillDirection.Horizontal

	if heroVertical then
		leftColumn.Size = UDim2.new(1, 0, 0, 522)
		centerColumn.Size = UDim2.new(1, 0, 0, 522)
		rightColumn.Size = UDim2.new(1, 0, 0, 522)
	else
		if mode == "tablet" then
			leftColumn.Size = UDim2.new(0.36, -12, 1, 0)
			centerColumn.Size = UDim2.new(0.38, -12, 1, 0)
			rightColumn.Size = UDim2.new(0.26, 0, 1, 0)
		else
			leftColumn.Size = UDim2.new(0.32, -12, 1, 0)
			centerColumn.Size = UDim2.new(0.39, -12, 1, 0)
			rightColumn.Size = UDim2.new(0.29, 0, 1, 0)
		end
	end

	tableCard.Visible = not isMobile
	mobileListCard.Visible = isMobile
end

local function refreshMode()
	local camera = workspace.CurrentCamera
	local size = camera and camera.ViewportSize or Vector2.new(1440, 900)
	local width = size.X

	local mode = "desktop"
	if width < 920 then
		mode = "mobile"
	elseif width < 1280 then
		mode = "tablet"
	end

	if mode ~= currentMode then
		if mode ~= "mobile" then
			sidebarOpen = false
		end
		applyMode(mode)
	end

	redrawChart(chartSeries[segmentActive])
end

local pulseAccumulator = 0
RunService.RenderStepped:Connect(function(deltaTime)
	pulseAccumulator += deltaTime
	local pulse = (math.sin(pulseAccumulator * 2.1) + 1) * 0.5
	heroStatusDot.BackgroundColor3 = theme.success:Lerp(Color3.fromRGB(100, 255, 168), pulse * 0.35)
	heroOrbBig.Rotation += deltaTime * 3
	heroOrbMid.Rotation -= deltaTime * 5

	if isMobile and sidebar.Parent == overlay then
		local targetPosition = sidebarOpen and UDim2.new(0, 20, 0, 20) or UDim2.new(0, -260, 0, 20)
		sidebar.Position = sidebar.Position:Lerp(targetPosition, math.clamp(deltaTime * 14, 0, 1))
		scrim.Visible = sidebarOpen or modal.Visible
		if not modal.Visible then
			scrim.BackgroundTransparency = scrim.BackgroundTransparency + ((sidebarOpen and 0.42 or 1) - scrim.BackgroundTransparency) * math.clamp(deltaTime * 10, 0, 1)
		end
	end
end)

