}
local chartDots = {}
local chartLines = {}

local function redrawChart(values)
	for _, line in ipairs(chartLines) do
		line:Destroy()
	end
	for _, dot in ipairs(chartDots) do
		dot:Destroy()
	end
	table.clear(chartLines)
	table.clear(chartDots)

	local width = chartCanvas.AbsoluteSize.X - 24
	local height = chartCanvas.AbsoluteSize.Y - 36
	if width <= 0 or height <= 0 then
		return
	end

	local points = {}
	local count = #values
	for index, value in ipairs(values) do
		local x = 12 + ((index - 1) / math.max(count - 1, 1)) * width
		local y = 12 + (1 - value) * height
		points[index] = Vector2.new(x, y)
	end

	for index = 1, #points - 1 do
		local a = points[index]
		local b = points[index + 1]
		local delta = b - a
		local length = delta.Magnitude
		local angle = math.deg(math.atan2(delta.Y, delta.X))
		local line = create("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			BackgroundColor3 = theme.accent,
			BorderSizePixel = 0,
			Position = UDim2.fromOffset(a.X, a.Y),
			Rotation = angle,
			Size = UDim2.fromOffset(length, 3),
			Parent = chartCanvas,
		})
		addCorner(line, 999)
		table.insert(chartLines, line)
	end

	for index, point in ipairs(points) do
		local dot = create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			BackgroundColor3 = theme.text,
			BorderSizePixel = 0,
			Position = UDim2.fromOffset(point.X, point.Y),
			Size = UDim2.fromOffset(index == #points and 10 or 8, index == #points and 10 or 8),
			Parent = chartCanvas,
		})
		addCorner(dot, 999)
		addStroke(dot, theme.accent, 2, 0)
		table.insert(chartDots, dot)
	end
end

