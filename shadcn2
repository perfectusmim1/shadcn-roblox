		Size = UDim2.fromScale(1, 1),
		Text = "!",
		TextColor3 = Color3.fromRGB(255, 227, 230),
		TextSize = 20,
		ZIndex = 102,
		Parent = iconWrap,
	})

	create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamSemibold,
		Position = UDim2.new(0, 0, 0, 62),
		Size = UDim2.new(1, 0, 0, 28),
		Text = options.Title or "Are you sure?",
		TextColor3 = theme.text,
		TextSize = 22,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 101,
		Parent = modal,
	})

	create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.Gotham,
		Position = UDim2.new(0, 0, 0, 96),
		Size = UDim2.new(1, 0, 0, 56),
		Text = options.Content or "This action cannot be undone.",
		TextColor3 = theme.textSoft,
		TextSize = 14,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		ZIndex = 101,
		Parent = modal,
	})

	local row = create("Frame", {
		AnchorPoint = Vector2.new(0, 1),
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 1, 0),
		Size = UDim2.new(1, 0, 0, 40),
		ZIndex = 101,
		Parent = modal,
	})
	layout(row, Enum.FillDirection.Horizontal, 10, Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Center)

	local cancelled = false
	local closed = false

	local function close()
		if closed then
			return
		end
		closed = true

		tween(overlay, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			BackgroundTransparency = 1,
		})
		tween(modalScale, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Scale = 0.93,
		})
		local out = tween(modal, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			BackgroundTransparency = 1,
			Position = UDim2.fromScale(0.5, 0.55),
		})
		out.Completed:Connect(function()
			if modal.Parent then
				modal:Destroy()
			end
			overlay.Visible = false
			if cancelled and options.OnCancel then
				options.OnCancel()
			end
		end)
	end

	local cancelButton = makeInteractiveButton(row, {
		Text = options.CancelText or "Cancel",
		Size = UDim2.new(0, 104, 0, 38),
		ZIndex = 101,
	})
	local confirmButton = makeInteractiveButton(row, {
		Text = options.ConfirmText or "Confirm",
		Size = UDim2.new(0, 112, 0, 38),
		Tone = options.Danger and "danger" or "primary",
		ZIndex = 101,
	})

	cancelButton.MouseButton1Click:Connect(function()
		cancelled = true
		close()
	end)

	confirmButton.MouseButton1Click:Connect(function()
		if options.OnConfirm then
			options.OnConfirm()
		end
		close()
	end)

	overlay.MouseButton1Click:Connect(function()
		if modal.Parent and not closed then
			cancelled = true
			close()
		end
	end)

	tween(modalScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
	tween(modal, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = UDim2.fromScale(0.5, 0.5),
	})
end

